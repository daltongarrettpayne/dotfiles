{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "Task",
      "TaskOutput",
      "WebFetch",
      "WebSearch",
      "Skill"
    ],
    "ask": [
      "Bash(command:rm *)",
      "Bash(command:sudo rm *)",
      "Bash(command:git push --force*)",
      "Bash(command:git reset --hard*)",
      "Write",
      "Edit"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gilfoyle@collide-marketplace": true,
    "coverage-enforcer@collide-marketplace": true,
    "azure-observability@collide-marketplace": true,
    "lua-lsp@claude-plugins-official": true
  },
  "model": "sonnet"
}
