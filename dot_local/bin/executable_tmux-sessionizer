#!/usr/bin/env bash
set -euo pipefail

# tmux run-shell uses a minimal env; Homebrew binaries aren't in PATH by default
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

REPOS="$HOME/Documents/repos"
TASKS_DIR="$REPOS/collide-tasks"

# ── Active sessions ────────────────────────────────────────────────────────────

ACTIVE=()
while IFS= read -r _line; do
  [[ -n "$_line" ]] && ACTIVE+=("$_line")
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

is_active() {
  local s; for s in "${ACTIVE[@]}"; do [[ "$s" == "$1" ]] && return 0; done; return 1
}

# ── Entry formatting ───────────────────────────────────────────────────────────
#
# 5 tab-delimited fields:
#   1: TYPE          — H (header) or E (entry); used by transform binding
#   2: SEARCH_TEXT   — plain text fzf matches against (no ANSI)
#   3: DISPLAY       — ANSI-formatted line shown to the user
#   4: SESSION_NAME  — extracted after selection
#   5: DIR           — working dir for new sessions (empty = $HOME)

NAME_COL=22      # max label width before truncation
CONTENT_WIDTH=36  # total usable line width (popup 42 - border 2 - pointer+gutter 4)
NAME_FIELD=$(( CONTENT_WIDTH - 2 - 8 ))  # 26: pads name so [active] is right-flush

header() {
  local label="$1"
  # 36 total width, minus 2 indent, minus 2 spaces around label = 32 for dashes
  local avail=$(( 32 - ${#label} ))
  (( avail < 0 )) && avail=0
  local left=$(( avail / 2 ))
  local right=$(( avail - left ))
  local ldashes rdashes
  printf -v ldashes '%.0s─' $(seq 1 "$left")
  printf -v rdashes '%.0s─' $(seq 1 "$right")
  printf 'H\t%s\t\033[2m  %s %s %s\033[0m\t\t\n' "$label" "$ldashes" "$label" "$rdashes"
}

# Blank separator line between groups (non-selectable, zero height in fzf)
gap() {
  printf 'H\t\t\t\t\n'
}

entry() {
  local label="$1" session="$2" dir="${3:-}"
  # Truncate display label so [active] never runs off the right edge
  if (( ${#label} > NAME_COL )); then
    label="${label:0:$((NAME_COL - 1))}…"
  fi
  local status="" display_status=""
  if is_active "$session"; then
    display_status=$'\033[32m[active]\033[0m'
    status="[active]"
  fi
  local display
  display=$(printf '  %-*s%s' "$NAME_FIELD" "$label" "$display_status")
  printf 'E\t%s %s\t%s\t%s\t%s\n' "$label" "$status" "$display" "$session" "$dir"
}

# ── All known names (used to detect orphan "Other" sessions) ──────────────────

KNOWN=("system" "scratch")
[[ -d "$REPOS/collide-core" ]] && KNOWN+=("collide-core")
if [[ -d "$TASKS_DIR" ]]; then
  for _d in "$TASKS_DIR"/*/; do
    [[ -d "$_d" ]] && KNOWN+=("$(basename "${_d%/}")")
  done
fi

# ── Build the full entry list ──────────────────────────────────────────────────
#
# Order is always: Meta → Projects → Other.
# --no-sort in fzf preserves this order after filtering.

generate() {
  header "Meta"
  entry "system"  "system"
  entry "scratch" "scratch"

  gap
  header "Projects"
  [[ -d "$REPOS/collide-core" ]] && entry "collide-core" "collide-core" "$REPOS/collide-core"
  if [[ -d "$TASKS_DIR" ]]; then
    for _d in "$TASKS_DIR"/*/; do
      [[ -d "$_d" ]] || continue
      local _n; _n="$(basename "${_d%/}")"
      entry "$_n" "$_n" "${_d%/}"
    done
  fi

  # Active sessions not in any known group
  local _others=()
  for _s in "${ACTIVE[@]}"; do
    local _found=false
    for _k in "${KNOWN[@]}"; do [[ "$_s" == "$_k" ]] && _found=true && break; done
    $_found || _others+=("$_s")
  done
  if (( ${#_others[@]} > 0 )); then
    gap
    header "Other"
    for _s in "${_others[@]}"; do entry "$(basename "$_s")" "$_s"; done
  fi
}

# ── Phase 1: outside popup — calculate height, open popup ─────────────────────

if [[ "${1:-}" != "--select" ]]; then
  count=$(generate | wc -l)
  height=$(( count + 5 ))  # popup border (×2) + fzf prompt + marker line + padding
  tmux display-popup \
    -E \
    -w 42 -h "$height" \
    -b rounded -S 'fg=#565f89' -s 'bg=#0f0f14' \
    "~/.local/bin/tmux-sessionizer --select"
  exit 0
fi

# ── Phase 2: inside popup — run fzf ───────────────────────────────────────────

# Tokyo Night palette, matched to the tmux theme in tmux.conf
FZF_COLORS="bg:#1a1b26,bg+:#1f2335,fg:#c0caf5,fg+:#c0caf5,\
hl:#7aa2f7,hl+:#7aa2f7,prompt:#7aa2f7,pointer:#9ece6a,\
info:#565f89,border:#27283d,gutter:#1a1b26,header:#565f89,\
marker:#9ece6a"

# Field layout: TYPE(1) \t SEARCH_TEXT(2) \t DISPLAY(3) \t SESSION(4) \t DIR(5)
#   --with-nth=3   → show only the DISPLAY field
#   --nth=2        → fuzzy-match only the SEARCH_TEXT field (no ANSI, clean)
#   transform      → noop when enter is pressed on a header (type=H)
#   alt-f          → close the picker (same key that opened it)

selected=$(
  generate | fzf \
    --ansi \
    --no-sort \
    --delimiter=$'\t' \
    --with-nth=3 \
    --layout=reverse \
    --prompt='   session > ' \
    --pointer='' \
    --no-info \
    --no-scrollbar \
    --border=none \
    --color="$FZF_COLORS" \
    --bind='ctrl-n:down,ctrl-p:up' \
    --bind='alt-f:abort' \
    --bind=$'enter:transform:[[ {1} == H ]] && echo noop || echo accept' \
) || exit 0

[[ -z "$selected" ]] && exit 0

# ── Selection handling ─────────────────────────────────────────────────────────

session=$(printf '%s' "$selected" | cut -f4 | tr . _)
dir=$(printf '%s' "$selected" | cut -f5)
start_dir="${dir:-$HOME}"

if ! tmux has-session -t "=$session" 2>/dev/null; then
  tmux new-session -ds "$session" -c "$start_dir"
fi

tmux switch-client -t "=$session"
