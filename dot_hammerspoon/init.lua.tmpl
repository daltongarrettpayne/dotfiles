-- Leader key navigation system
-- Right Command (remapped to F17 via Karabiner-Elements) activates leader mode.
--
-- HOLD F17 + key  (while key is held down):
--   1/2/3          switch workspace instantly
--   shift+1/2/3    move focused window to workspace instantly
--
-- TAP F17, then key sequence:
--   ?              cheat sheet (q to dismiss)
--   o              workspace back-and-forth
--   b              Arc
--   m              TIDAL
--   1/2/3          switch workspace
--   shift+1/2/3    move focused window to workspace
--   c → s          Slack
--   c → m          Mail
--   c → c          Calendar
--   c → n          Notion
--   c → g          Granola  (work only)
--   d → t          WezTerm
--   d → p          Postico 2
--   s → f          Finder
--   s → s          System Settings
--   s → v          OpenVPN Connect
--   w → f          fullscreen toggle
--   w → m          minimize window
--   r → h          reload Hammerspoon
--   r → s          reload Sketchybar
--   r → a          reload Aerospace config
--
--   Shift on any category action pulls the app into the current workspace:
--   c → shift+s    pull Slack into current workspace

local AEROSPACE = "/opt/homebrew/bin/aerospace"
local TIMEOUT   = 2.0

-- Modifier keycodes — keypresses to silently ignore in sequential leader mode
local MODIFIER_CODES = {
  [54]=true, [55]=true,  -- left/right cmd
  [56]=true, [60]=true,  -- left/right shift
  [58]=true, [61]=true,  -- left/right opt
  [59]=true, [62]=true,  -- left/right ctrl
  [63]=true,             -- fn
}

-- ── App definitions ───────────────────────────────────────────────────────────
-- name  → used by launchOrFocus (go-to)
-- id    → used by pullApp (move window to current workspace)
-- cmd   → used for direct commands (no app launch)

local apps = {
  c = {
    s = { name = "Slack",           id = "com.tinyspeck.slackmacgap" },
    m = { name = "Mail",            id = "com.apple.mail" },
{{- if eq .machineType "work" }}
    c = { name = "Notion Calendar", id = "com.cron.electron" },
    n = { name = "Notion",          id = "notion.mail.id" },
    g = { name = "Granola",         id = "com.granola.app" },
{{- else }}
    c = { name = "Calendar",        id = "com.apple.iCal" },
{{- end }}
  },
  d = {
    t = { name = "WezTerm",         id = "com.github.wez.wezterm" },
    p = { name = "Postico 2",       id = "at.eggerapps.Postico" },
  },
  s = {
    f = { name = "Finder",          id = "com.apple.finder" },
    s = { name = "System Settings", id = "com.apple.systempreferences" },
    v = { name = "OpenVPN Connect", id = "org.openvpn.client.app" },
  },
  w = {
    f = { cmd = function() hs.execute(AEROSPACE .. " fullscreen") end },
    m = { cmd = function()
      local win = hs.window.focusedWindow()
      if win then win:minimize() end
    end },
  },
  r = {
    h = { cmd = function() hs.alert.show("Hammerspoon reloaded", 0.5); hs.timer.doAfter(0.5, hs.reload) end },
    s = { cmd = function() hs.execute("sketchybar --reload"); hs.alert.show("Sketchybar reloaded", 0.5) end },
    a = { cmd = function() hs.execute(AEROSPACE .. " reload-config"); hs.alert.show("Aerospace reloaded", 0.5) end },
  },
}

-- ── Pull: move an app's window into the current workspace ─────────────────────

local function pullApp(bundleId)
  local focused = hs.execute(AEROSPACE .. " list-workspaces --focused"):gsub("%s+", "")
  local output  = hs.execute(AEROSPACE .. " list-windows --all --format '%{window-id}|%{app-bundle-id}'")
  for line in output:gmatch("[^\n]+") do
    local winId, appId = line:match("^(.+)|(.+)$")
    if winId and appId then
      if appId:gsub("%s+", "") == bundleId then
        hs.execute(AEROSPACE .. " move-node-to-workspace --window-id " .. winId:gsub("%s+", "") .. " " .. focused)
        return
      end
    end
  end
end

-- ── Workspace actions (shared between held and tap modes) ─────────────────────

local function switchWorkspace(name)
  hs.execute(AEROSPACE .. " workspace " .. name)
end

local wsSwitch = {
  ["1"] = function() switchWorkspace("01-dev") end,
  ["2"] = function() switchWorkspace("02-bench") end,
  ["3"] = function() switchWorkspace("03-hold") end,
}

local wsMove = {
  ["1"] = function() hs.execute(AEROSPACE .. " move-node-to-workspace 01-dev --focus-follows-window") end,
  ["2"] = function() hs.execute(AEROSPACE .. " move-node-to-workspace 02-bench --focus-follows-window") end,
  ["3"] = function() hs.execute(AEROSPACE .. " move-node-to-workspace 03-hold --focus-follows-window") end,
}

