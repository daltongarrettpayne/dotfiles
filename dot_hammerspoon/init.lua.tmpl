-- ── Held mode ─────────────────────────────────────────────────────────────────
-- Active while F17 is physically held. 1/2/3 switch workspaces immediately.

local heldActionTaken = false
local heldWatcher

heldWatcher = hs.eventtap.new({ hs.eventtap.event.types.keyDown }, function(event)
  local char  = hs.keycodes.map[event:getKeyCode()]
  local shift = event:getFlags().shift

  if char and shift and wsMove[char] then
    wsMove[char]()
    heldActionTaken = true
    return true
  end

  if char and wsSwitch[char] then
    wsSwitch[char]()
    heldActionTaken = true
    return true
  end

  return false  -- pass everything else through
end)

-- ── Sequential leader mode (tap path) ────────────────────────────────────────

local state = { active = false, category = nil, timer = nil }
local keyWatcher

local function reset(sendEscape)
  state.active   = false
  state.category = nil
  if state.timer then state.timer:stop(); state.timer = nil end
  if keyWatcher  then keyWatcher:stop() end
  if sendEscape  then hs.eventtap.keyStroke({}, "escape") end
end

local function startTimeout()
  if state.timer then state.timer:stop() end
  state.timer = hs.timer.doAfter(TIMEOUT, function() reset(true) end)
end

local direct = {

  ["1"] = wsSwitch["1"],
  ["2"] = wsSwitch["2"],
  ["3"] = wsSwitch["3"],
  b     = function() hs.application.launchOrFocus("Arc") end,
  m     = function() hs.application.launchOrFocus("TIDAL") end,
}

keyWatcher = hs.eventtap.new({ hs.eventtap.event.types.keyDown }, function(event)
  local keyCode = event:getKeyCode()
  local char    = hs.keycodes.map[keyCode]
  local shift   = event:getFlags().shift

  if MODIFIER_CODES[keyCode] then return true end
  if keyCode == 53 then reset(false); return true end  -- escape cancels

  startTimeout()

  if state.category then
    local cat = apps[state.category]
    if cat and char and cat[char] then
      local entry = cat[char]
      if entry.cmd then
        entry.cmd()
      elseif shift then
        pullApp(entry.id)
      else
        hs.application.launchOrFocus(entry.name)
      end
    end
    reset(false)
    return true
  end

  -- ? (shift+/) → cheat sheet
  if shift and char == "/" then
    showCheatsheet()
    reset(false)
    return true
  end

  if shift and char and wsMove[char] then
    wsMove[char]()
    reset(false)
    return true
  end

  if char and direct[char] then
    direct[char]()
    reset(false)
    return true
  end

  if char and apps[char] then
    state.category = char
    return true
  end

  reset(false)
  return true
end)

-- ── F17 hotkey: hold vs tap ───────────────────────────────────────────────────

hs.hotkey.bind({}, "f17",
  function()  -- keydown: start held mode
    heldActionTaken = false
    heldWatcher:start()
  end,
  function()  -- keyup: if nothing was pressed during hold, activate tap/leader mode
    heldWatcher:stop()
    if not heldActionTaken then
      if state.active then reset(false); return end
      state.active   = true
      state.category = nil
      keyWatcher:start()
      startTimeout()
    end
  end,
  function()  -- key repeat: do nothing (prevents toggle spam while held)
  end
)
