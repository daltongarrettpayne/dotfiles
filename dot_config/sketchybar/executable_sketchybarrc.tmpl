##### Focus Session #####
sketchybar --add item focus_title center \
           --set focus_title drawing=off \
                             icon.drawing=off \
                             label.font="Hack Nerd Font:Bold:15.0" \
                             label.color=0xffffffff \
                             label.padding_left=0 \
                             label.padding_right=0 \
                             width=0 \
                             y_offset=20 \
           --add item focus center \
           --set focus update_freq=1 \
                       script="$PLUGIN_DIR/focus.sh" \
                       drawing=off \
                       icon.drawing=off \
                       label.font="Hack Nerd Font:Bold:11.0" \
                       label.color=0xff888888 \
                       y_offset=-13 \
                       label.padding_left=10 \
                       label.padding_right=10

##### Adding Aerospace Workspaces #####
# source "$ITEM_DIR/aerospace.sh"
source "$ITEM_DIR/aerospace_compact.sh"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update


