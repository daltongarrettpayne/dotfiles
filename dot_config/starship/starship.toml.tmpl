format = """
$directory\
$git_branch\
$git_status\
$fill\
$jobs\
$line_break\
$character"""

add_newline = true
palette = "nord"

[directory]
style = 'bold fg:dark_blue'
format = '[$path ]($style)'
truncation_length = 3
truncation_symbol = 'ÔÇª/'
truncate_to_repo = false

[directory.substitutions]
'Documents' = '¾░êÖ'
'Downloads' = '´ÇÖ '
'Music' = '´Çü '
'Pictures' = '´Ç¥ '

[git_branch]
style = 'fg:green'
symbol = '´Éÿ '
format = '[on](white) [$symbol$branch ]($style)'

[git_status]
style = 'fg:red'
format = '([$all_status$ahead_behind]($style) )'
conflicted = '¾░¢£'
ahead = '¾░£À'
behind = '¾░£«'
diverged = '¾░╣║'
up_to_date = '¾░ä¼'
untracked = '¾░ïù'
stashed = '¾░åô'
modified = '¾░Å½'
staged = '¾░Éû'
renamed = '¾░æò'
deleted = '¾░ù¿'
typechanged = '¾▒ÇÀ'

[fill]
symbol = ' '

[python]
disabled = true

[lua]
disabled = true

[nodejs]
style = 'blue'
symbol = '¯£ÿ '

[golang]
